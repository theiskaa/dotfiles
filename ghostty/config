# Window configuration
window-padding-x = 10
window-padding-y = 10
macos-titlebar-style = hidden
background-opacity = 1
background-blur = 15

theme = "hybrid"
# theme = "hybrid" # Soft Light Dark
# theme = "flexoki-dark" # Soft Dark
# theme = "cga" # Dark

# Fonts
font-size = 13
font-family = "Monaspace"
font-thicken

# Mouse settings
mouse-hide-while-typing = true

# Tmux keybindings
# NOTE: Ghostty 1.2.0 added default cmd+1..9 (and reworked key names to W3C
# codes). Logical triggers like `cmd+1` no longer override Ghostty's own
# defaults, so these use *physical* key names (digit_N, key_X, bracket_*,
# comma) which take precedence and pass the byte through to tmux.

# Rename window
keybind = cmd+comma=text:\x02,

# Select session
keybind = cmd+key_k=text:\x02s

# Select windows 1-9
keybind = cmd+digit_1=text:\x021
keybind = cmd+digit_2=text:\x022
keybind = cmd+digit_3=text:\x023
keybind = cmd+digit_4=text:\x024
keybind = cmd+digit_5=text:\x025
keybind = cmd+digit_6=text:\x026
keybind = cmd+digit_7=text:\x027
keybind = cmd+digit_8=text:\x028
keybind = cmd+digit_9=text:\x029

# Switch to last session
keybind = cmd+key_l=text:\x02L
keybind = cmd+bracket_left=text:\x02[

# Previous window
keybind = shift+cmd+bracket_left=text:\x02p

# Split panes
keybind = shift+cmd+key_n=text:\x02%
keybind = cmd+key_n=text:\x02\"

# Next window
keybind = shift+cmd+bracket_right=text:\x02n

# Save in neovim
keybind = cmd+key_s=text:\x1b:w\n

# New window and break pane
keybind = cmd+key_t=text:\x02c
keybind = shift+cmd+key_t=text:\x02!

# Kill pane
keybind = cmd+key_w=text:\x02x

# Toggle zoom
keybind = cmd+key_z=text:\x02z
